## ── Code-only academic upload ──

# Scratch / temporary work — kept local, never uploaded
_tmp_*
*.ps1
# style sandbox, not part of the deliverable
sources/R/utils/style_exploration.R

# Kept local and reusable, but out of the code upload to keep it lean
sources/R/article/
sources/R/utils/
sources/R/protocol_panels.R
sources/R/export_article_figures.R
